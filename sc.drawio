<mxGraphModel dx="1100" dy="760" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ЗАГОЛОВОК И ЛЕГЕНДА -->
    <mxCell id="Title" value="Вектор атаки KC-1: фишинг бухгалтера → захват домена → эксфильтрация ПДн → шифрование" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#B20000;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="820" height="26" as="geometry"/></mxCell>
    <mxCell id="Legend" value="→ красная стрелка = сетевой переход (номер этапа Kill Chain);  рамка с номером = локальное действие;  розовый блок = недопустимое последствие (Н.x)" style="text;html=1;fontSize=11;fontColor=#666666;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="46" width="900" height="20" as="geometry"/></mxCell>

    <!-- СУБЪЕКТЫ И УЗЛЫ -->
    <mxCell id="Attacker_WAN" value="Атакующий&#10;(преступная группа, Н3)" style="shape=mxgraph.basic.actor;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#990000;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="90" height="90" as="geometry"/></mxCell>
    <mxCell id="Internet" value="Сеть Интернет" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="380" y="90" width="150" height="80" as="geometry"/></mxCell>
    <mxCell id="MikroTik_FW" value="MikroTik RB3011&#10;RouterOS 6.45.9&#10;10.10.10.1 — МЭ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1"><mxGeometry x="385" y="210" width="140" height="55" as="geometry"/></mxCell>
    <mxCell id="Squid_Proxy" value="Squid 4.6 (DMZ)&#10;10.10.50.10&#10;исходящий C2/exfil 443" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1"><mxGeometry x="660" y="210" width="160" height="55" as="geometry"/></mxCell>
    <mxCell id="Buh_Victim_PC" value="АРМ Бухгалтер (ЖЕРТВА)&#10;Win10 1909 (18363.476)&#10;10.10.30.11 / VLAN 30&#10;1С 8.3.16, Office 2016, Chrome 80" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="370" y="330" width="180" height="80" as="geometry"/></mxCell>
    <mxCell id="GlavBuh_PC" value="АРМ Гл. бухгалтер&#10;Win10 1909 / 10.10.30.10&#10;банк-клиент, утв. платежей" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="100" y="335" width="160" height="60" as="geometry"/></mxCell>
    <mxCell id="DC_Server" value="Контроллер домена&#10;WinSrv2019 (17763.1039)&#10;10.10.20.10 / VLAN 20" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="660" y="335" width="170" height="60" as="geometry"/></mxCell>
    <mxCell id="App1C_Server" value="Сервер приложений 1С&#10;Ubuntu 20.04 (5.4.0-42)&#10;10.10.20.11" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="370" y="480" width="180" height="60" as="geometry"/></mxCell>
    <mxCell id="PG_Server" value="СУБД PostgreSQL 12.5&#10;Ubuntu 20.04 / 10.10.20.12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="660" y="480" width="170" height="60" as="geometry"/></mxCell>
    <mxCell id="NAS_Synology" value="NAS Synology DS220+&#10;DSM 6.2.3 / 10.10.25.10&#10;резервные копии, сканы" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1"><mxGeometry x="370" y="630" width="180" height="60" as="geometry"/></mxCell>

    <!-- СЕТЕВЫЕ ПЕРЕХОДЫ (красные нумерованные стрелки) -->
    <mxCell id="e1" value="1. Разведка (OSINT)" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="Attacker_WAN" target="Internet"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" value="2. Фишинг (SMTP→OWA) + CVE-2017-11882" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="Internet" target="Buh_Victim_PC"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="ec2" value="C2 / выгрузка (HTTPS 443)" style="endArrow=block;html=1;dashed=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontSize=9;" edge="1" parent="1" source="Buh_Victim_PC" target="Squid_Proxy"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6a" value="6. Боковое перемещение: SMBGhost CVE-2020-0796" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="Buh_Victim_PC" target="GlavBuh_PC"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6b" value="6. Валидные УЗ 1С / SSH (1540-1565, 22)" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="Buh_Victim_PC" target="App1C_Server"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7a" value="7. ZeroLogon CVE-2020-1472 → DCSync (ДК доступен из всех VLAN)" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="Buh_Victim_PC" target="DC_Server"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8a" value="8. Дамп базы 1С (TCP 5432) — ПДн работников" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="App1C_Server" target="PG_Server"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8b" value="8. SMB 445 — контрагенты, фин. архивы" style="endArrow=block;html=1;strokeColor=#FF0000;strokeWidth=2;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="DC_Server" target="NAS_Synology"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e9" value="9. Шифрование / уничтожение (T1486 / T1490)" style="endArrow=block;html=1;dashed=1;strokeColor=#FF0000;strokeWidth=3;fontColor=#B20000;fontStyle=1;fontSize=10;" edge="1" parent="1" source="PG_Server" target="NAS_Synology"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ЛОКАЛЬНЫЕ ДЕЙСТВИЯ (текстовые блоки с номером этапа) -->
    <mxCell id="t3" value="3. Закрепление: задача планировщика + Run-key; локальный SYSTEM — SMBGhost (CVE-2020-0796)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B20000;dashed=1;fontColor=#B20000;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="570" y="320" width="220" height="40" as="geometry"/></mxCell>
    <mxCell id="t4" value="4. Дамп учётных данных: LSASS, Kerberoasting (сервис 1С), Chrome 80 (ДБО/ЭДО), Credential Manager" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B20000;dashed=1;fontColor=#B20000;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="570" y="372" width="220" height="44" as="geometry"/></mxCell>
    <mxCell id="t5" value="5. Внутренняя разведка: перечисление AD; скан VLAN 20 (1С 1540-1565, OWA 443), NAS 445" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B20000;dashed=1;fontColor=#B20000;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="100" y="455" width="200" height="44" as="geometry"/></mxCell>
    <mxCell id="t7b" value="7. Локальный root на серверах 1С/СУБД: CVE-2021-3156 (sudo) / CVE-2021-3493 (OverlayFS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B20000;dashed=1;fontColor=#B20000;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="660" y="550" width="200" height="44" as="geometry"/></mxCell>

    <!-- НЕДОПУСТИМЫЕ ПОСЛЕДСТВИЯ (розовые блоки) -->
    <mxCell id="dmg_N23" value="Н.23: имущественный ущерб — хищение средств и подмена реквизитов через банк-клиент" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#990000;fontStyle=2;fontSize=9;" vertex="1" parent="1"><mxGeometry x="90" y="240" width="185" height="55" as="geometry"/></mxCell>
    <mxCell id="dmg_N4" value="Н.4: нарушение тайны переписки сотрудников (доступ к почте/AD)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#990000;fontStyle=2;fontSize=9;" vertex="1" parent="1"><mxGeometry x="870" y="335" width="170" height="55" as="geometry"/></mxCell>
    <mxCell id="dmg_N11" value="Н.11: простой бухгалтерии и отдела кадров — недополучение прибыли" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#990000;fontStyle=2;fontSize=9;" vertex="1" parent="1"><mxGeometry x="90" y="560" width="185" height="55" as="geometry"/></mxCell>
    <mxCell id="dmg_N16" value="Н.16: незапланированные затраты на восстановление серверов, ВМ и учётной базы" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontColor=#990000;fontStyle=2;fontSize=9;" vertex="1" parent="1"><mxGeometry x="600" y="630" width="200" height="55" as="geometry"/></mxCell>

  </root>
